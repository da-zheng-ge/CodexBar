{
  "name": "codexbar",
  "version": "0.1.1",
  "description": "Windows taskbar quota bar for Codex.",
  "author": "da-zheng-ge",
  "main": "src/main.js",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "start": "electron .",
    "check": "node --check src/main.js && node --check src/preload.js && node --check src/renderer.js && node --check src/win32.js",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --win portable nsis"
  },
  "build": {
    "appId": "com.codexbar.app",
    "productName": "CodexBar",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "koffi": "^2.12.0"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^26.15.3"
  }
}
